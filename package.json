{
	"name": "news-manage",
	"private": true,
	"version": "2.0.0",
	"type": "module",
	"scripts": {
		"dev": "concurrently \"vite\" \"json-server --watch --port 5000 db.json\"",
		"build": "tsc -b && vite build",
		"preview": "vite preview",
		"serve:json": "json-server --watch --port 5000 db.json",
		"check": "biome check --write .",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@ant-design/icons": "^6.1.0",
		"@lexical/html": "^0.41.0",
		"@lexical/link": "^0.41.0",
		"@lexical/list": "^0.41.0",
		"@lexical/react": "^0.41.0",
		"@lexical/rich-text": "^0.41.0",
		"@lexical/selection": "^0.41.0",
		"@lexical/utils": "^0.41.0",
		"@tsparticles/engine": "^3.9.1",
		"@tsparticles/react": "^3.0.0",
		"@tsparticles/slim": "^3.9.1",
		"antd": "^6.3.1",
		"date-fns": "^4.1.0",
		"echarts": "^6.0.0",
		"lexical": "^0.41.0",
		"nprogress": "^0.2.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-router": "^7.13.1",
		"tsparticles": "^3.9.1",
		"zustand": "^5.0.11"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.5",
		"@types/node": "^25.3.3",
		"@types/nprogress": "^0.2.3",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.1.4",
		"concurrently": "^9.2.1",
		"json-server": "^0.17.4",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	},
	"pnpm": {
		"overrides": {
			"esbuild": "^0.26.0",
			"@esbuild/*": "^0.26.0"
		},
		"onlyBuiltDependencies": [
			"esbuild"
		]
	}
}
